{
	"name": "saucedemo",
	"version": "1.0.0",
	"license": "ISC",
	"type": "module",
	"scripts": {
		"test": "wdio run local.wdio.conf.js",
		"test-ci": "wdio run ci.wdio.conf.js",
		"allure:generate": "allure generate ./artifacts/allure-results --clean -o ./artifacts/allure-report",
		"allure:open": "allure open ./artifacts/allure-report",
		"allure:clean": "rm -rf ./artifacts/allure-results ./artifacts/allure-report",
		"test-and-allure": "npm-run-all --continue-on-error --serial test allure:generate allure:open",
		"artifacts:clean": "rm -rf ./artifacts"
	},
	"dependencies": {
		"lodash-es": "^4.17.21",
		"winston": "^3.19.0",
		"chai": "^4.3.7",
		"dotenv": "^17.2.4"
	},
	"devDependencies": {
		"@wdio/allure-reporter": "^9.23.3",
		"@wdio/cli": "^9.23.2",
		"@wdio/cucumber-framework": "^9.23.2",
		"@wdio/local-runner": "^9.23.2",
		"@wdio/spec-reporter": "^9.23.2",
		"allure-commandline": "^2.36.0",
		"npm-run-all": "^4.1.5"
	}
}
